# ─────────────────────────────────────────────────────────────────────────────
# Edgebric — Production Environment Variables
#
# Copy this file to .env.production and fill in all values.
# DO NOT commit .env.production to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────

# The public URL where users access Edgebric (used for CORS + OIDC redirect)
FRONTEND_URL=https://edgebric.yourcompany.com

# Random 64+ char string for signing session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED in production — server refuses to start without it.
SESSION_SECRET=

# ─── Authentication (OIDC/SSO) ──────────────────────────────────────────────

# Your identity provider's issuer URL
# Google:    https://accounts.google.com
# Microsoft: https://login.microsoftonline.com/{tenant}/v2.0
# Okta:      https://your-org.okta.com
OIDC_ISSUER=https://accounts.google.com

# OAuth 2.0 client credentials from your IdP
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Must match the redirect URI registered in your IdP
OIDC_REDIRECT_URI=https://edgebric.yourcompany.com/api/auth/callback

# ─── Access Control ─────────────────────────────────────────────────────────

# Comma-separated emails that get admin access after SSO login
ADMIN_EMAILS=admin@yourcompany.com

# ─── Ollama Inference ────────────────────────────────────────────────────────

# Ollama endpoint (usually on the same machine)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model
EMBEDDING_MODEL=nomic-embed-text

# ─── Chat Inference ─────────────────────────────────────────────────────────

# OpenAI-compatible chat endpoint (defaults to Ollama's /v1 API)
# Override to use llama-server, vLLM, or any OpenAI-compatible endpoint.
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_API_KEY=ollama
CHAT_MODEL=qwen3:4b
