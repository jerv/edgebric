{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "paths": {
      "@edgebric/types": ["./shared/types/src/index.ts"],
      "@edgebric/core": ["./packages/core/src/index.ts"],
      "@edgebric/core/ingestion": ["./packages/core/src/ingestion/index.ts"],
      "@edgebric/core/rag": ["./packages/core/src/rag/index.ts"],
      "@edgebric/edge": ["./packages/edge/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/dist"]
}
