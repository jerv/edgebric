{
  "name": "edgebric",
  "private": true,
  "version": "0.9.53",
  "packageManager": "pnpm@10.6.4",
  "scripts": {
    "build": "pnpm -r --filter=!@edgebric/web build && pnpm --filter @edgebric/web build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "flatted": ">=3.4.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
