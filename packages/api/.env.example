PORT=3001
DATA_DIR=./data

# OIDC Authentication
# Supported providers: google, microsoft, okta, onelogin, ping, generic
# The provider ID determines claims mapping and profile picture handling.
# If OIDC_PROVIDER is not set, it's auto-detected from the OIDC_ISSUER URL.
OIDC_PROVIDER=google

# Provider-specific issuer URLs:
#   Google:    https://accounts.google.com
#   Microsoft: https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:      https://<your-domain>.okta.com
#   OneLogin:  https://<subdomain>.onelogin.com/oidc/2
#   Ping:      https://auth.pingone.com/<environment-id>/as
#   Generic:   Your provider's issuer URL
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=<your-client-id>
OIDC_CLIENT_SECRET=<your-client-secret>
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Comma-separated emails that get admin access after SSO login
ADMIN_EMAILS=you@gmail.com

# Random 32+ char string for signing session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<your-session-secret>

# mimik edge node
MIMIK_BASE_URL=http://localhost:8083
MIMIK_API_KEY=your-milm-api-key-here
MILM_MODEL=qwen2.5-1.5b-instruct
EMBEDDING_MODEL=nomic-embed-text
