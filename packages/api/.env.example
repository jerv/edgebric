PORT=3001
DATA_DIR=./data

# OIDC — Google as IdP (dev). Replace OIDC_ISSUER for other providers.
# Create a Web application OAuth 2.0 client at console.cloud.google.com.
# Add http://localhost:3001/api/auth/callback as an authorized redirect URI.
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=<your-google-client-id>
OIDC_CLIENT_SECRET=<your-google-client-secret>
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Comma-separated emails that get admin access after SSO login
ADMIN_EMAILS=you@gmail.com

# Random 32+ char string for signing session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<your-session-secret>

# mimik edge node
MIMIK_BASE_URL=http://localhost:8083
MIMIK_API_KEY=your-milm-api-key-here
MILM_MODEL=qwen2.5-1.5b-instruct
EMBEDDING_MODEL=nomic-embed-text
