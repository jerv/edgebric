{
  "name": "@edgebric/desktop",
  "version": "0.9.5",
  "private": true,
  "description": "Edgebric — Private knowledge platform that runs on your hardware",
  "author": "Edgebric",
  "repository": "github:jerv/edgebric",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder --mac",
    "package:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.edgebric.desktop",
    "productName": "Edgebric",
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.business"
    },
    "extraResources": [
      "resources/**"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "appdmg": "^0.6.6",
    "electron": "33.4.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.0"
  }
}
